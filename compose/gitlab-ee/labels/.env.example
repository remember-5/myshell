# GitLab 实例地址，私有部署请改成自己的域名。
GITLAB_HOST=https://gitlab.com

# 需要操作的 group ID，可在 GitLab group 页面查看。
GROUP_ID=1

# 拥有 api 权限的 Access Token。
GITLAB_TOKEN=your_token_here

# 标签定义文件路径。默认就是当前目录下的 labels.json。
LABELS_FILE=./labels.json

# true: 只打印操作，不真正调用 GitLab API。
DRY_RUN=false

# 删除脚本专用确认开关。
CONFIRM_DELETE_LABELS=no
