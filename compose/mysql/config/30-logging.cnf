[mysqld]
# 错误日志
log_error = /logs/mysql-error.log
log_error_verbosity = 2
log_timestamps = SYSTEM

# 慢查询日志
slow_query_log = ON
slow_query_log_file = /logs/mysql-slow.log
long_query_time = 2
log_slow_admin_statements = ON
log_queries_not_using_indexes = OFF

# 审计替代方案
# MySQL 社区版不包含 Enterprise Audit，这里保留 general log 的文件路径，
# 默认关闭，排障时再临时开启。
log_output = FILE
general_log = OFF
general_log_file = /logs/mysql-general.log
log_raw = OFF
